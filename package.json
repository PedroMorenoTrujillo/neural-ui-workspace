{
  "name": "neural-ui-workspace",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "build": "node scripts/build-ui-core.mjs",
    "build:watch": "node scripts/build-ui-core.mjs --watch",
    "figma:sync": "node scripts/figma-export.mjs",
    "audit:primitives": "node scripts/audit-ui-core-primitives.mjs",
    "audit:entrypoints": "node scripts/audit-ui-core-entrypoints.mjs",
    "audit:cva": "node scripts/audit-ui-core-cva-contracts.mjs",
    "audit:bundle": "node scripts/audit-ui-core-bundle.mjs",
    "test:imports": "node scripts/test-ui-core-entrypoint-imports.mjs",
    "test:ssr-smoke": "node scripts/test-ui-core-ssr-smoke.mjs",
    "test": "ng test ui-core --watch=false",
    "test:coverage": "ng test ui-core --watch=false --coverage",
    "sandbox": "ng serve sandbox --open"
  },
  "private": true,
  "packageManager": "npm@10.9.7",
  "overrides": {
    "esbuild": "0.27.3",
